# ─────────────────────────────────────────────────────────────────────────────
# Syncsity — Environment Configuration
# Copy to .env (never commit .env). Set chmod 600 .env on the server.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=production           # production | development
APP_URL=https://syncsity.com
APP_NAME=Syncsity

# A 64+ char random string used to salt IP hashes & sign sessions.
# Generate: php -r "echo bin2hex(random_bytes(32));"
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# ── Database (cPanel MySQL) ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=syncsity_main
DB_USER=syncsity_app
DB_PASS=set-a-strong-password

# ── Email (Exim local SMTP on HostFluid) ────────────────────────────────────
MAIL_PROVIDER=smtp           # smtp | native
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=hello@syncsity.com
SMTP_PASS=set-the-cpanel-mailbox-password
SMTP_ENCRYPTION=tls          # tls | ssl | none

MAIL_FROM_EMAIL=hello@syncsity.com
MAIL_FROM_NAME=Syncsity
MAIL_REPLY_TO=edward@syncsity.com
MAIL_NOTIFY_INTERNAL=edward@syncsity.com

# ── OpenRouter (LLM) ────────────────────────────────────────────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_FALLBACK=anthropic/claude-3.5-haiku
OPENROUTER_REFERER=https://syncsity.com
OPENROUTER_TITLE=Syncsity Revenue Intelligence Engine

# ── Google Sheets (lead trail) ──────────────────────────────────────────────
# Path to the service-account JSON (place outside web root, chmod 600).
# Share the target sheet with the service-account's client_email as Editor.
GOOGLE_SERVICE_ACCOUNT_JSON=/home/syncsity/credentials/syncsity-sheets.json
GOOGLE_SHEETS_LEADS_ID=             # The sheet ID from its URL
GOOGLE_SHEETS_LEADS_RANGE=Leads!A1
GOOGLE_SHEETS_REPORTS_RANGE=Reports!A1

# ── Optional: Calendly (strategy session booking) ───────────────────────────
CALENDLY_STRATEGY_URL=https://calendly.com/syncsity/strategy

# ── Rate limits ─────────────────────────────────────────────────────────────
ASSESS_PER_EMAIL_PER_DAY=3
MAGIC_LINK_PER_EMAIL_PER_HOUR=3
CONTACT_PER_IP_PER_HOUR=5
